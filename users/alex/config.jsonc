			"keyColor": "cyan"
		},
		{
			"type": "theme",
			"key": "├─󰉼",
			"keyColor": "cyan"
		},
		{
			"type": "icons",
			"key": "╰─󰀻",
			"keyColor": "cyan"
		},
		"break",
		{
			"type": "terminal",
			"key": "╭─",
			"keyColor": "blue"
		},
		{
			"type": "terminalfont",
			"key": "├─",
			"keyColor": "blue"
		},
		{
			"type": "shell",
			"key": "╰─",
			"keyColor": "blue"
		},
		"break",
		{
			"type": "host",
			"key": "╭─",
			"keyColor": "white"
		},
		{
			"type": "uptime",
			"key": "├─󰅐",
			"keyColor": "white"
