		},
		{
			"type": "packages",
			"key": "├─󰮯",
			"keyColor": "cyan"
		},
		{
			"type": "de",
			"key": "├─",
			"keyColor": "cyan"
		},
		{
			"type": "wm",
			"key": "├─",
			"keyColor": "cyan"
		},
		{
			"type": "lm",
